<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Permissions"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This app needs two special permissions to track your usage:"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Usage Access"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Required to track screen time and app usage."
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/usageAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Usage Access"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Notification Access"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Required to track notifications."
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/notificationAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Notification Access"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permission Status:\n✗ Usage Access: Not Granted\n✗ Notification Access: Not Granted"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"
            android:fontFamily="monospace"/>

        <Button
            android:id="@+id/continueButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue to Dashboard"
            android:textSize="18sp"
            android:padding="16dp"
            android:enabled="false"/>

    </LinearLayout>

</ScrollView>
