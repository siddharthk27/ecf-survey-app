<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/studyDayText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Day 1 of 10"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data from: Yesterday"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- Summary Cards -->
        <androidx.cardview.widget.CardView
            android:id="@+id/summaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/screenTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Screen Time: 0h 0m"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/unlocksText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Unlocks: 0"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/notificationsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notifications: 0"
                    android:textSize="16sp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Screen Time Chart -->
        <androidx.cardview.widget.CardView
            android:id="@+id/screenTimeChartCard"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen Time Trend"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/screenTimeChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- App Usage Pie Chart -->
        <androidx.cardview.widget.CardView
            android:id="@+id/appUsageChartCard"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yesterday's App Usage"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/appUsageChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Top Apps -->
        <androidx.cardview.widget.CardView
            android:id="@+id/topAppsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/topAppsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Top Apps:\n• Loading..."
                android:textSize="14sp"
                android:fontFamily="monospace"/>

        </androidx.cardview.widget.CardView>

        <!-- Top Unlock Apps -->
        <androidx.cardview.widget.CardView
            android:id="@+id/topUnlockAppsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/topUnlockAppsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Apps Opened After Unlock:\n• Loading..."
                android:textSize="14sp"
                android:fontFamily="monospace"/>

        </androidx.cardview.widget.CardView>

        <!-- Top Notification Apps -->
        <androidx.cardview.widget.CardView
            android:id="@+id/topNotificationAppsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/topNotificationAppsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Most Notifications:\n• Loading..."
                android:textSize="14sp"
                android:fontFamily="monospace"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
